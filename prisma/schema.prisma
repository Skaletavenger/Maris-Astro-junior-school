generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  name      String?
  createdAt DateTime @default(now())
}

model SchoolDocument {
  id        String   @id @default(cuid())
  url       String
  name      String
  createdAt DateTime @default(now())
}
